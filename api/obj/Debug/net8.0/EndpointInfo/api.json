    "/api/Application": {
      "post": {
        "tags": [
          "Application"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "CV",
                  "JobOfferId"
                ],
                "type": "object",
                "properties": {
                  "JobOfferId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "CV": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "JobOfferId": {
                  "style": "form"
                },
                "CV": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Application/GetGroupedApplications": {
      "get": {
        "tags": [
