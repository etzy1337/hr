    "/api/JobOffer": {
      "get": {
        "tags": [
          "JobOffer"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "JobOffer"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddJobOfferDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddJobOfferDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddJobOfferDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/JobOffer/{id}": {
      "get": {
        "tags": [
          "JobOffer"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
